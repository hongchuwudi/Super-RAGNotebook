# ==============================================
# 前端服务端口与访问配置
# ==============================================
# Vite 开发服务器监听地址。0.0.0.0 表示允许局域网访问；仅本机访问可改为 127.0.0.1。
FRONTEND_HOST=0.0.0.0
# Vite 开发服务器端口。
FRONTEND_PORT=10100
# 前端代理到后端的目标地址。通过 start.py 全量启动时会由 config/.env 注入覆盖。
VITE_BACKEND_TARGET=http://127.0.0.1:10000

# ==============================================
# 其他配置
# ==============================================
# 前端 API 请求超时时间，单位毫秒。
VITE_API_TIMEOUT_MS=30000
