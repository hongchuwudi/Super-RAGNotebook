# ==============================================
# RAGNotebook 全局启动配置
# ==============================================
# start.py 只读取项目根目录 config/.env，并将配置注入给：
# 1. PostgreSQL Docker Compose
# 2. FastAPI 后端服务
# 3. Vite 前端服务
#
# 注意：
# - config/.env 用于一键启动和统一管理。
# - config/apikey.txt 保存真实模型 API Key，不要提交。
# - front/.env 仅作为手动单独启动前端时的回退配置。

# ==============================================
# 服务端口与访问配置
# ==============================================
# 后端监听地址。0.0.0.0 表示允许局域网访问；仅本机访问可改为 127.0.0.1。
BACKEND_HOST=0.0.0.0
# 后端监听端口。修改后，start.py 会自动把前端代理目标同步到该端口。
BACKEND_PORT=10000
# 前端监听地址。0.0.0.0 表示允许局域网访问；仅本机访问可改为 127.0.0.1。
FRONTEND_HOST=0.0.0.0
# 前端开发服务器端口。
FRONTEND_PORT=10100
# 端口被占用时是否直接失败：false 自动寻找后续可用端口；true 端口冲突时直接退出。
STRICT_PORTS=false
# 前端代理到后端的目标地址。完整前后端启动时，start.py 会根据 BACKEND_HOST/BACKEND_PORT 自动覆盖此值。
VITE_BACKEND_TARGET=http://127.0.0.1:10000
# 前端 API 请求超时时间，单位毫秒。
VITE_API_TIMEOUT_MS=30000
# 后端 CORS 白名单，多个来源用英文逗号分隔。若修改 FRONTEND_PORT，也请同步修改这里的端口。
CORS_ALLOW_ORIGINS=http://localhost:10100,http://127.0.0.1:10100

# ==============================================
# 数据库配置
# ==============================================
# PostgreSQL 连接字符串。优先级高于 POSTGRES_* 分项配置。
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_notebook
# PostgreSQL 用户名。
POSTGRES_USER=rag
# PostgreSQL 密码。修改 Docker 已初始化的数据卷后，需要同步修改数据库内用户密码。
POSTGRES_PASSWORD=rag
# PostgreSQL 主机。Docker 本地启动通常为 localhost。
POSTGRES_HOST=localhost
# PostgreSQL 端口。
POSTGRES_PORT=5432
# PostgreSQL 数据库名。
POSTGRES_DB=rag_notebook
# 启动 PostgreSQL 后等待端口可连接的最长时间，单位秒。
DB_STARTUP_TIMEOUT=60
# 一键启动时等待后端模型/索引/重排序全部就绪后再启动前端的最长时间，单位秒。
BACKEND_READY_TIMEOUT=300
# SQLAlchemy 连接池基础连接数。
DB_POOL_SIZE=10
# SQLAlchemy 连接池最大溢出连接数。
DB_MAX_OVERFLOW=20
# 是否打印 SQL 语句。调试 SQL 时可设为 true，日常建议 false。
SQL_ECHO=false
# 后端启动时是否自动初始化空数据库。已有业务表时会跳过；需要强制迁移请手动执行 pg_auto_init --force。
PG_AUTO_INIT=true
# 旧式 create_all 兜底开关，仅建议本地临时验证使用。正常开发和部署应保持 false。
DB_AUTO_CREATE_TABLES=false

# ==============================================
# 模型配置 - 共享连接
# ==============================================
# 阿里云百炼 API Key 文件路径。不要在 config/.env 里填写真实 sk-xxxx；请写入同目录 apikey.txt。
ALIYUN_ACCESS_KEY_SECRET=apikey.txt
# 阿里云百炼 OpenAI 兼容接口地址，供阿里云模型共享。
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama 服务地址，供 Ollama LLM、嵌入、视觉模型共享。
OLLAMA_BASE_URL=http://localhost:11434

# ==============================================
# 模型配置 - LLM
# ==============================================
# 大语言模型类型：ALIYUN（阿里云百炼）| OLLAMA（本地 Ollama）。
LLM_TYPE=ALIYUN
# 阿里云聊天模型名称。
CHAT_MODEL_NAME=qwen3-max
# Ollama 聊天模型名称。使用前需先执行 ollama pull 下载。
OLLAMA_MODEL_NAME=qwen3.5:0.8b

# ==============================================
# 模型配置 - 嵌入
# ==============================================
# 嵌入模型类型：ALIYUN | OLLAMA。
EMBED_MODEL_TYPE=ALIYUN
# 阿里云嵌入模型名称。仅 EMBED_MODEL_TYPE=ALIYUN 时使用。
ALIYUN_EMBED_MODEL_NAME=text-embedding-v4
# Ollama 嵌入模型名称。仅 EMBED_MODEL_TYPE=OLLAMA 时使用。
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
# pgvector embedding 列维度。需与当前嵌入模型实际输出维度一致。
EMBEDDING_DIM=1024

# ==============================================
# 模型配置 - 视觉
# ==============================================
# 视觉模型类型：ALIYUN | OLLAMA。必须显式填写，不再默认沿用 LLM_TYPE。
VISION_MODEL_TYPE=ALIYUN
# 阿里云视觉模型名称，建议使用 qwen-vl 系列。
VISION_CHAT_MODEL_NAME=qwen-vl-max
# Ollama 视觉模型名称。仅 VISION_MODEL_TYPE=OLLAMA 时使用。
VISION_OLLAMA_MODEL_NAME=qwen-vl:7b
# 多模态 PDF 每批处理页数。越大越省调用次数，但单页描述粒度可能下降。
VISION_BATCH_SIZE=5
# 是否启用图片感知哈希去重。PPT 或模板类 PDF 通常建议开启。
VISION_DEDUP_ENABLED=true
# 感知哈希距离阈值，范围 0-64；越小越严格。
VISION_DEDUP_THRESHOLD=10
# 批处理视觉模型时是否使用低分辨率图片，以节省 token 和传输体积。
VISION_BATCH_LOW_RES=true

# ==============================================
# 模型配置 - 重排序
# ==============================================
# 重排序模型本地路径。不存在时会尝试从 ModelScope 下载。
RERANKER_MODEL_PATH=D:\Hugging_Face\models\bge-reranker-v2-m3

# ==============================================
# 其他配置
# ==============================================
# 全局限流开关。开发调试可设为 false，生产环境建议 true。
RATE_LIMIT_ENABLED=false
# JWT 签名密钥。生产环境务必修改为足够复杂的随机字符串。
SECRET_KEY=MY_JWT_SECRET_KWY_FOR_USR_AND_I_JUST_WRITE_THIS
# JWT 签名算法。
ALGORITHM=HS256
